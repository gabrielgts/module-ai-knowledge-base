<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="gtstudio_ai_knowledge_base" resource="default" engine="innodb" comment="AiKnowledgeBase">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity Id Column"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Title Column"/>
        <column xsi:type="text" name="content" nullable="false" comment="Content Column"/>
        <column xsi:type="varchar" name="tags" nullable="false" length="255" comment="Tags Column"/>
        <column xsi:type="boolean" name="is_active" nullable="false" comment="Is Active Column"/>
        <column xsi:type="text" name="agent_ids" nullable="true" comment="Comma-separated agent entity IDs"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At Column"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" default="CURRENT_TIMESTAMP" nullable="false" comment="Updated At Column"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="GTSTUDIO_AI_KNOWLEDGE_BASE_ENTITY_ID" indexType="btree">
            <column name="entity_id"/>
        </index>
        <index referenceId="GTSTUDIO_AI_KNOWLEDGE_BASE_FULLTEXT" indexType="fulltext">
            <column name="title"/>
            <column name="content"/>
            <column name="tags"/>
        </index>
    </table>
</schema>
